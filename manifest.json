        {
          "runtime": "claude",
          "configDir": "$HOME/.claude",
          "args": [
            "--claude",
            "--global",
            "--profile=full"
          ]
        },
        {
          "runtime": "codex",
          "configDir": "$HOME/.codex",
          "args": [
            "--codex",
            "--global",
            "--profile=full"
          ]
        },
        {
          "runtime": "gemini",
          "configDir": "$HOME/.gemini",
          "args": [
            "--gemini",
            "--global",
            "--profile=full"
          ]
        },
        {
          "runtime": "antigravity",
          "configDir": "$HOME/.gemini/config",
          "args": [
            "--antigravity",
            "--global",
            "--profile=full"
          ]
        }
      ],
      "notes": "Runs the official GSD npm installer for runtime-specific files, then mirrors GSD skills into ~/.agents/skills."
    },
    {
      "id": "playwright-cli-official",
      "type": "playwright-cli-installer",
      "package": "@playwright/cli@latest",
      "repo": "https://github.com/microsoft/playwright-cli.git",
      "skills": [
        "playwright-cli"
      ],
      "notes": "Runs the official Playwright CLI skill installer in a temporary workspace and copies the generated playwright-cli skill into each configured root."
    }
