{
  "version": 6,
  "name": "agentic-supercharge",
  "description": "Safe interactive upstream-first AI skill setup for Claude Code, Codex, .agents, Gemini CLI, Antigravity, Cursor, and local projects.",
  "schemaDescription": "Schema version 6 keeps verified pinned source refs/packages by default, adds official OpenAI and Vercel Labs skills sources, optional tracking refs/packages for --allow-upstream-drift, local public-safe skills, official installer metadata, root policies, exclusions, router smoke checks, and AS-Workflow runtime/knowledge-vault metadata.",
  "asWorkflow": {
    "version": 1,
    "projectStateDir": ".agenticsupercharge",
    "knowledgeDir": ".agenticsupercharge/knowledge",
    "knowledgeIndex": ".agenticsupercharge/knowledge-index.json",
    "runtimeRoot": "$HOME/.agentic-supercharge/runtime/current",
    "shim": "$HOME/.agentic-supercharge/bin/agentic-supercharge",
    "disableEnv": "AGENTIC_SUPERCHARGE_WORKFLOW=disabled",
    "notes": "AS-Workflow is local project runtime state and is gitignored by default."
  },
  "installRoots": [
    "$HOME/.claude/skills",
    "$HOME/.codex/skills",
    "$HOME/.agents/skills",
    "$HOME/.gemini/skills",
    "$HOME/.gemini/config/skills",
    "$HOME/.cursor/skills"
  ],
  "globalInstructionFiles": [
    {
      "runtime": "claude-code",
      "from": "global-instructions/CLAUDE.md",
      "to": "$HOME/.claude/CLAUDE.md",
      "description": "Claude Code global user instructions"
    },
    {
      "runtime": "codex",
      "from": "global-instructions/AGENTS.md",
      "to": "$HOME/.codex/AGENTS.md",
      "description": "Codex global AGENTS.md instructions"
    },
    {
      "runtime": "gemini-antigravity",
      "from": "global-instructions/GEMINI.md",
      "to": "$HOME/.gemini/GEMINI.md",
      "description": "Gemini CLI and Antigravity global instructions"
    }
  ],
  "rootPolicies": {
    "claudeOnlySkills": [],
    "rootSkillSkips": [
      {
        "rootSuffix": "/.claude/skills",
        "skills": [
          "security-review"
        ],
        "reason": "Claude Code has a native /security-review command; the portable security-review skill is installed for non-Claude runtimes."
      }
    ]
  },
  "exclusions": {
    "forbiddenSkillNames": [
      "googledrive-automation",
      "google-drive-automation",
      "google_drive-automation"
    ],
    "forbiddenPathFragments": [
      "composio-skills",
      "googledrive-automation",
      "google-drive-automation",
      "google_drive-automation"
    ],
    "notes": [
      "Do not bulk-install Composio's massive composio-skills automation tree.",
      "Do not copy secrets, auth sessions, API keys, OAuth state, or MCP credentials."
    ]
  },
