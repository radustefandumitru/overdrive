{
  "name": "agentic-supercharge",
  "version": "0.9.0",
  "description": "Safe interactive installer for portable AI coding-agent skills across Claude Code, Codex, Gemini, Antigravity, Cursor, and local projects.",
  "license": "MIT",
  "bin": {
    "agentic-supercharge": "bin/agentic-supercharge.js"
  },
  "files": [
    "bin/",
    "lib/",
    "scripts/",
    "evals/",
    "skills/",
    "global-instructions/",
    "docs/",
    "manifest.json",
    "README.md",
    "PUBLISHING.md",
    "MCP_AND_CONNECTORS.md",
    "THIRD_PARTY_NOTICES.md",
    "SKILLS_SUMMARY.md",
    "SKILLS_TLDR.md",
    "SECURITY.md",
    "VERIFIED_SOURCES.md",
    "AGENTS_OPENAI_YAML.md",
    "CHANGELOG.md",
    "LICENSE",
    "install.sh",
    "verify.sh",
    "check-updates.sh",
    "update.sh",
    "uninstall.sh"
  ],
  "scripts": {
    "check": "node --check lib/installer.js && node --check lib/as-workflow.js && node --check bin/agentic-supercharge.js && node --check scripts/check-consistency.js && node --check scripts/evaluate-router.js && node --check scripts/test-as-workflow.js && node --check scripts/build-scorecard.js && node --check scripts/analyze-routes.js",
    "consistency": "node scripts/check-consistency.js",
    "eval:router": "node scripts/evaluate-router.js",
    "test:workflow": "node scripts/test-as-workflow.js",
    "dry-run": "node bin/agentic-supercharge.js --dry-run",
    "verify": "node bin/agentic-supercharge.js verify && npm run consistency && npm run eval:router && npm run test:workflow && npm run analyze:routes",
    "check-updates": "node bin/agentic-supercharge.js check-updates",
    "self-update": "node bin/agentic-supercharge.js self-update",
    "update-skills": "node bin/agentic-supercharge.js update-skills",
    "uninstall": "node bin/agentic-supercharge.js uninstall",
    "scorecard": "node scripts/build-scorecard.js",
    "analyze:routes": "node scripts/analyze-routes.js"
  },
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/radustefandumitru/AgenticSupercharge.git"
  },
  "bugs": {
    "url": "https://github.com/radustefandumitru/AgenticSupercharge/issues"
  },
  "homepage": "https://github.com/radustefandumitru/AgenticSupercharge#readme"
}
